factory.ARITHMODYNAMIC.COAL.number = 5
factory.ARITHMODYNAMIC.COTTON.number = 0
factory.ARITHMODYNAMIC.WHEAT.number = 5
factory.ARITHMODYNAMIC.FOOD.number = 0
factory.ARITHMODYNAMIC.CLOTHING.number = 0
factory.ARITHMODYNAMIC.KILOWATT.number = 0
factory.ARITHMODYNAMIC.REALESTATE.number = 0
factory.ARITHMODYNAMIC.MACHINE.number = 0



centralBank.reserveRatio = 0.1
centralBank.inflationTarget = 0.02
centralBank.targetPriceIndex = 15

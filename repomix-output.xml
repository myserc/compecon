	}

	@Override
	public String getName() {
		return name;
	}

	@Override
	public boolean getOverdraftPossible() {
		return overdraftPossible;
	}

	@Override
	public BankCustomer getOwner() {
		return owner;
	}

	@Override
	public TermType getTermType() {
		return termType;
	}


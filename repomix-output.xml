		assertPartialDerivativesPerPriceAreEqual(cobbDouglasFunction, optimalInputsIterative, priceFunctions);
		assertPartialDerivativesPerPriceAreEqual(cobbDouglasFunction, optimalInputsBruteForce, priceFunctions);
	}
}
